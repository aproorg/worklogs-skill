# Slack
SLACK_BOT_TOKEN=xoxp-your-slack-user-token
SLACK_USER_EMAIL=you@example.com

# Google OAuth2 (path to credentials.json from Google Cloud Console)
GOOGLE_OAUTH_CREDENTIALS=./credentials.json

# Github
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your-github-username

# Jira
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=you@example.com
JIRA_TOKEN=your-jira-api-token

# Tempo (optional — for logging hours to Atlassian Tempo)
TEMPO_TOKEN=your-tempo-api-token

# LiteLLM (optional — for estimation refinement)
LITELLM_URL=
LITELLM_API_KEY=
LITELLM_MODEL=
